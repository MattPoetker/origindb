{
  "entries": ["./examples/todo/index.ts"],
  "targets": {
    "debug": {
      "outFile": "build/module.debug.wasm",
      "textFile": "build/module.debug.wat",
      "sourceMap": false,
      "debug": true
    },
    "release": {
      "outFile": "build/module.wasm",
      "optimizeLevel": 3,
      "shrinkLevel": 1,
      "converge": false,
      "noAssert": false
    }
  },
  "options": {
    "runtime": "minimal",
    "exportRuntime": false,
    "importMemory": false,
    "use": ["abort=assembly/index/__origindb_abort"]
  }
}
